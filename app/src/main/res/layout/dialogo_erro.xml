<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="350dp"
    android:layout_height="wrap_content"
    android:background="@drawable/bg_dialog_rounded"
    android:padding="16dp">

    <!-- Botão fechar (X) -->
    <ImageButton
        android:id="@+id/btnFecharX"
        android:layout_width="36dp"
        android:layout_height="36dp"
        android:background="@drawable/bg_close_button"
        android:src="@android:drawable/ic_menu_close_clear_cancel"
        android:contentDescription="Fechar"
        android:padding="8dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <!-- Imagem do gato -->
    <ImageView
        android:id="@+id/imgGato"
        android:layout_width="80dp"
        android:layout_height="80dp"
        android:src="@drawable/gato_erro"
        android:contentDescription="Gato erro"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"/>

    <!-- Título -->
    <TextView
        android:id="@+id/tvErroTitulo"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="Erro ao fazer o Login"
        android:textStyle="bold"
        android:textSize="18sp"
        android:textColor="#D32F2F"
        app:layout_constraintStart_toEndOf="@id/imgGato"
        app:layout_constraintEnd_toStartOf="@id/btnFecharX"
        app:layout_constraintTop_toTopOf="parent"
        android:layout_marginStart="12dp"
        android:layout_marginEnd="8dp"/>

    <!-- Mensagem -->
    <TextView
        android:id="@+id/tvErroMensagem"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="CPF ou senha inválidos!"
        android:textSize="14sp"
        android:textColor="#333"
        app:layout_constraintStart_toStartOf="@id/tvErroTitulo"
        app:layout_constraintTop_toBottomOf="@id/tvErroTitulo"
        app:layout_constraintEnd_toEndOf="@id/tvErroTitulo"
        android:layout_marginTop="8dp"/>

    <!-- Botão OK -->
    <Button
        android:id="@+id/btnFechar"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:paddingHorizontal="30dp"
        android:text="OK"
        app:layout_constraintTop_toBottomOf="@id/tvErroMensagem"
        app:layout_constraintEnd_toEndOf="@id/tvErroMensagem"
        android:layout_marginTop="16dp"/>

</androidx.constraintlayout.widget.ConstraintLayout>